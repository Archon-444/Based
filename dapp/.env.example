# ================================
# BASE BLOCKCHAIN (Primary)
# ================================

VITE_BASE_CHAIN_ID=84532
VITE_BASE_RPC_URL=https://sepolia.base.org

# Contract addresses (deployed to Base Sepolia)
VITE_FACTORY_ADDRESS=0x...
VITE_AMM_ADDRESS=0x...
VITE_CONDITIONAL_TOKENS_ADDRESS=0x...
VITE_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Coinbase Smart Wallet — gasless transactions (optional)
# Get from https://portal.cdp.coinbase.com
VITE_CDP_PAYMASTER_URL=

# ================================
# API CONFIGURATION
# ================================

VITE_API_URL=/api

# ================================
# WALLET INTEGRATION
# ================================

# WalletConnect v2 project ID — get from https://cloud.walletconnect.com
# Required to enable mobile wallet pairing
VITE_WALLETCONNECT_PROJECT_ID=

# Coinbase OnchainKit App ID (optional)
VITE_BASE_ONCHAINKIT_APP_ID=

# ================================
# FEATURE FLAGS
# ================================

VITE_ENABLE_PUSH_NOTIFICATIONS=false
VITE_ENABLE_BIOMETRIC_AUTH=false
VITE_ENABLE_SERVICE_WORKER=false

# ================================
# LOGGING
# ================================

# Options: DEBUG, INFO, WARN, ERROR
# VITE_LOG_LEVEL=INFO
