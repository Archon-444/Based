# ===================================
# Based - Environment Configuration
# ===================================
# Copy this file to .env and fill in your values
# NEVER commit .env files to version control!

# ============ Application ============
NODE_ENV=development
APP_NAME="Based"
APP_URL=http://localhost:5173
API_URL=http://localhost:4000
VITE_API_URL=http://localhost:4000
VITE_BACKEND_URL=http://localhost:4000

# ============ Base Configuration ============
BASE_RPC_URL=https://sepolia.base.org
BASE_WS_URL=wss://base-sepolia.publicnode.com
VITE_BASE_CHAIN_ID=84532

# Contract Addresses (Base Sepolia)
MARKET_FACTORY_ADDRESS=0x51baebd534f1b56003dcf11587874f9c9fa6f41a
AMM_ADDRESS=0x5c775990facaddcc608a7770f78a8e57f401b93e
CONDITIONAL_TOKENS_ADDRESS=0xaf64d3778a5c065499e2ce22bf94d949ea353c87
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

VITE_FACTORY_ADDRESS=0x51baebd534f1b56003dcf11587874f9c9fa6f41a
VITE_AMM_ADDRESS=0x5c775990facaddcc608a7770f78a8e57f401b93e
VITE_CONDITIONAL_TOKENS_ADDRESS=0xaf64d3778a5c065499e2ce22bf94d949ea353c87
VITE_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Admin wallet
ADMIN_PRIVATE_KEY=0x...  # NEVER commit this!

# ============ Oracle Configuration ============
# Pyth Network
PYTH_CONTRACT_ADDRESS=0xA2aa501b19aff244D90cc15a4Cf739D2725B5729
PYTH_API_ENDPOINT=https://hermes.pyth.network

# UMA Optimistic Oracle V3
UMA_OOV3_ADDRESS=0x0F7fC5E6482f096380db6158f978167b57388deE
UMA_BOND_AMOUNT=500

# ============ Database (PostgreSQL) ============
DATABASE_URL=postgresql://postgres:password@localhost:5432/prediction_market

# ============ Redis Cache ============
REDIS_URL=redis://localhost:6379

# ============ API Configuration ============
PORT=4000

# ============ AI Agents (Optional) ============
AGENT_ENABLED=false
AGENT_AUTO_RESOLVE=false
AGENT_AUTO_DISPUTE=false
AGENT_COMMENTARY_ENABLED=false
AGENT_CONFIDENCE_THRESHOLD=80
AGENT_DISPUTE_CONFIDENCE_THRESHOLD=90
